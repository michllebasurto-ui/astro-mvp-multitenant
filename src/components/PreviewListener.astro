<script>
  // Notify parent window that preview is ready
  window.parent.postMessage({ type: 'PREVIEW_READY' }, '*');

  // Restrict to same origin or the parent's origin
  const trustedOrigin = document.referrer
    ? new URL(document.referrer).origin
    : window.location.origin;

  window.addEventListener('message', (event: MessageEvent) => {
    // Only accept messages from the parent origin
    if (event.origin !== trustedOrigin) return;

    const { type, payload } = event.data ?? {};

    if (type === 'UPDATE_COLORS') {
      // payload: { primary: '#hex' }
      if (payload?.primary) {
        document.documentElement.style.setProperty('--color-primary', payload.primary);
      }
    } else if (type === 'UPDATE_COMPONENT') {
      // payload: { section: 'hero', field: 'headline', value: 'New text' }
      const { section, field, value } = payload ?? {};
      if (section && field) {
        const el = document.querySelector(`[data-section="${section}"][data-field="${field}"]`);
        if (el) el.textContent = value ?? '';
      }
    } else if (type === 'TOGGLE_COMPONENT') {
      // payload: { section: 'whatsapp', visible: false }
      const { section, visible } = payload ?? {};
      if (section !== undefined) {
        const el = document.querySelector(`[data-section="${section}"]`);
        if (el instanceof HTMLElement) {
          el.style.display = visible === false ? 'none' : '';
        }
      }
    }
  });
</script>
