---
import "../styles/global.css";
import type { TenantData } from "../lib/types";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  tenant?: TenantData | null;
  noIndex?: boolean;
}

const {
  title,
  description = "",
  ogImage,
  canonicalUrl,
  tenant = null,
  noIndex = false,
} = Astro.props;

const currentUrl = canonicalUrl || Astro.url.href;
const origin = Astro.url.origin;

const brandName = tenant?.config.brandName;
const rawPrimaryColor = tenant?.config.primaryColor;
// Validate primaryColor to prevent CSS injection (allow hex, rgb, hsl, named colors)
const primaryColor =
  rawPrimaryColor && /^(#[0-9a-fA-F]{3,8}|rgb\([^)]+\)|hsl\([^)]+\)|[a-zA-Z]+)$/.test(rawPrimaryColor)
    ? rawPrimaryColor
    : undefined;
const faviconUrl = tenant?.config.logo || "/favicon.svg";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brandName || title,
  url: origin,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* Favicon */}
    {
      faviconUrl.startsWith("/") ? (
        <link rel="icon" type="image/svg+xml" href={faviconUrl} />
      ) : (
        <link rel="icon" type="image/png" href={faviconUrl} />
      )
    }

    {/* SEO: Canonical URL */}
    <link rel="canonical" href={currentUrl} />

    {/* SEO: Robots */}
    {noIndex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    {brandName && <meta property="og:site_name" content={brandName} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* JSON-LD structured data */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* CSS custom properties for tenant colors */}
    {primaryColor && (
      <style set:html={`:root { --color-primary: ${primaryColor}; }`} />
    )}

    {/* Additional head content from pages */}
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
