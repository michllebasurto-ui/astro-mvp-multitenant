---
import { resolveTenantAndPage } from '../lib/tenant';
import { getTemplateComponent } from '../lib/template-registry';

const { page } = Astro.params;
const pagePath = `/${page}`;

const resolved = resolveTenantAndPage(Astro.request, pagePath);

if (!resolved) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { tenant, pageData } = resolved;
const Component = getTemplateComponent(tenant.template, pageData.page);

if (!Component) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
---
<Component tenant={tenant} pageData={pageData} request={Astro.request} />
