---
import {
  resolveTenant,
  resolvePageForTenant,
  buildTenantUrl,
} from "../lib/tenant";
import { getTemplateComponent } from "../lib/template-registry";
import NotFoundPage from "../templates/_shared/NotFoundPage.astro";

const { page } = Astro.params;
const pageSlug = `/${page}`;

// Resolve tenant ONCE
const tenantResult = await resolveTenant(Astro.request);

// Resolve page using already-resolved tenant (no second resolveTenant call)
const resolved = tenantResult
  ? resolvePageForTenant(tenantResult.tenant, tenantResult.tenantSlug, pageSlug)
  : null;

// If tenant + page found → load component
let Component: any = null;
if (resolved) {
  Component = await getTemplateComponent(
    resolved.tenant.template,
    resolved.page.page,
  );
}

// Determine if 404
const is404 = !tenantResult || !resolved || !Component;

if (is404) {
  Astro.response.status = 404;
}

// Prepare data for tenant's 404 page
const url = new URL(Astro.request.url);
const useQueryParam = url.searchParams.has("tenant");
const tenantSlug = tenantResult?.tenantSlug || "";
const homeUrl = tenantResult
  ? buildTenantUrl(Astro.request, tenantSlug, "/")
  : "/";
---

{
  is404 ? (
    <NotFoundPage
      brandName={tenantResult?.tenant.config.brandName}
      primaryColor={tenantResult?.tenant.config.primaryColor}
      homeUrl={homeUrl}
      requestedPage={page}
      config={tenantResult?.tenant.config}
      tenantSlug={tenantSlug}
      useQueryParam={useQueryParam}
    />
  ) : (
    <Component
      tenant={resolved.tenant}
      pageData={resolved.page}
      request={Astro.request}
    />
  )
}
