---
import { resolveTenantAndPage } from '../lib/tenant';
import { getTemplateComponent } from '../lib/template-registry';

const { page } = Astro.params;
const pageSlug = `/${page}`;

const resolved = await resolveTenantAndPage(Astro.request, pageSlug);

if (!resolved) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { tenant, page: resolvedPage } = resolved;
const Component = await getTemplateComponent(tenant.template, resolvedPage.page);

if (!Component) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
---
<Component tenant={tenant} pageData={resolvedPage} request={Astro.request} />
