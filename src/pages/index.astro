---
import { resolvePageForTenant } from "../lib/tenant";
import { getTemplateComponent } from "../lib/template-registry";
import DefaultHome from "../templates/default/pages/Home.astro";

const { tenant, tenantSlug } = Astro.locals;

let resolved = null;
let PageComponent: any = null;

if (tenant && tenantSlug) {
  resolved = resolvePageForTenant(tenant, tenantSlug, "/");
  if (resolved) {
    PageComponent = await getTemplateComponent(tenant.template, resolved.page.page);
  }
}
---

{
  PageComponent && resolved ? (
    <PageComponent
      tenant={resolved.tenant}
      pageData={resolved.page}
      request={Astro.request}
    />
  ) : (
    <DefaultHome />
  )
}
