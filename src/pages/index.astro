---
import { resolveTenantAndPage } from '../lib/tenant';
import { getTemplateComponent } from '../lib/template-registry';
import DefaultHome from '../templates/default/pages/Home.astro';

const resolved = await resolveTenantAndPage(Astro.request, '/');

let PageComponent: any = null;

if (resolved) {
  const { tenant, page } = resolved;
  PageComponent = await getTemplateComponent(tenant.template, page.page);
}
---
{PageComponent && resolved ? (
  <PageComponent tenant={resolved.tenant} pageData={resolved.page} request={Astro.request} />
) : (
  <DefaultHome />
)}
