---
interface Service {
  name: string;
  description: string;
  price: string;
}
interface Category {
  name: string;
  icon: string;
  services: Service[];
}
interface Props {
  categories: Category[];
  primaryColor?: string;
}
const { categories, primaryColor = "#1e40af" } = Astro.props;
---

<div class="space-y-10">
  {
    categories.map((cat) => (
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">{cat.icon}</span>
          <h3 class="text-2xl font-bold text-gray-900">{cat.name}</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {cat.services.map((service) => (
            <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow hover:border-blue-200">
              <h4 class="font-bold text-gray-900 mb-2">{service.name}</h4>
              <p class="text-gray-500 text-sm mb-4">{service.description}</p>
              <p class="font-bold text-lg" style={`color: ${primaryColor}`}>
                {service.price}
              </p>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</div>
