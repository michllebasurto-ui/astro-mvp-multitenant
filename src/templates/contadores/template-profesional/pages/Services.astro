---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Navbar from "../../../_shared/Navbar.astro";
import Footer from "../../../_shared/Footer.astro";
import WhatsAppButton from "../../../_shared/WhatsAppButton.astro";
import ServicesList from "../components/ServicesList.astro";
import type { TenantData, PageData } from "../../../../lib/tenant";

interface Props {
  tenant: TenantData;
  pageData: PageData;
  request: Request;
}

const { tenant, pageData, request } = Astro.props;
const url = new URL(request.url);
const useQueryParam = url.searchParams.has("tenant");
const tenantSlug = url.searchParams.get("tenant") || "";
const content = pageData.content as any;
---

<BaseLayout title={pageData.meta.title} description={pageData.meta.description}>
  <div class="min-h-screen flex flex-col bg-slate-50">
    <Navbar
      config={tenant.config}
      currentPath="/services"
      tenantSlug={tenantSlug}
      useQueryParam={useQueryParam}
    />

    <main class="flex-1 py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl font-bold text-gray-900 mb-4">
            Nuestros Servicios
          </h1>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Soluciones contables y fiscales adaptadas a tus necesidades, con
            precios claros y sin sorpresas.
          </p>
        </div>
        {
          content.categories && (
            <ServicesList
              categories={content.categories}
              primaryColor={tenant.config.primaryColor}
            />
          )
        }
        <div
          class="mt-12 bg-blue-50 rounded-2xl p-8 text-center border border-blue-100"
        >
          <h3 class="text-2xl font-bold text-blue-900 mb-4">
            ¿No encuentras lo que buscas?
          </h3>
          <p class="text-blue-700 mb-6">
            Ofrecemos servicios personalizados. Contáctanos para una consulta
            sin costo.
          </p>
          <a
            href={useQueryParam ? `/contact?tenant=${tenantSlug}` : "/contact"}
            class="inline-block bg-blue-800 text-white font-bold py-3 px-8 rounded-lg hover:bg-blue-900 transition-colors"
          >
            Consulta Gratuita
          </a>
        </div>
      </div>
    </main>

    <Footer
      config={tenant.config}
      tenantSlug={tenantSlug}
      useQueryParam={useQueryParam}
    />
    {
      tenant.config.whatsapp && (
        <WhatsAppButton phone={tenant.config.whatsapp} />
      )
    }
  </div>
</BaseLayout>
