---
interface FoodItem {
  name: string;
  description: string;
  price: string;
  emoji: string;
}
interface Props {
  items: FoodItem[];
  primaryColor?: string;
}
const { items, primaryColor = '#ea580c' } = Astro.props;
---
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {items.map((item) => (
    <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden group">
      <div class="h-32 flex items-center justify-center text-6xl" style={`background-color: ${primaryColor}15`}>
        {item.emoji}
      </div>
      <div class="p-5">
        <h3 class="font-bold text-gray-900 text-lg mb-1">{item.name}</h3>
        <p class="text-gray-500 text-sm mb-3">{item.description}</p>
        <div class="flex items-center justify-between">
          <span class="font-bold text-xl" style={`color: ${primaryColor}`}>{item.price}</span>
          <button class="text-white text-sm font-bold py-2 px-4 rounded-full transition-opacity hover:opacity-90" style={`background-color: ${primaryColor}`}>
            Pedir
          </button>
        </div>
      </div>
    </div>
  ))}
</div>
